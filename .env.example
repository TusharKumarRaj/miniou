# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/dev

# API (apps/api)
PORT=8000
NODE_ENV=development
BASE_URL=http://localhost:8000
APP_URL=http://localhost:8000

# Web (apps/web)
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/trpc

# Auth
JWT_SECRET=replace-with-long-random-string

# Google OAuth (Google Cloud Console → Web client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email verification (https://resend.com — required for email/password signup in production)
RESEND_API_KEY=
EMAIL_FROM=miniou <noreply@yourdomain.com>

# Corsair credential encryption (openssl rand -hex 32)
CORSAIR_KEK=

# OpenAI (meeting chat + scope classifier)
OPENAI_API_KEY=

# Webhooks (optional — Gmail push via Pub/Sub)
# Full topic resource name, e.g. projects/my-project/topics/miniou-gmail
GMAIL_PUBSUB_TOPIC=
# Defaults to JWT_SECRET when omitted
WEBHOOK_TENANT_SECRET=

# Meeting rate limits (optional — defaults shown)
MEETING_RATE_LIMIT_MAX=20
MEETING_RATE_LIMIT_WINDOW_MS=3600000
